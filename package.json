{
  "name": "cursor-sync",
  "displayName": "Cursor Sync",
  "description": "Sync user-level Cursor settings and assets to a private GitHub Gist",
  "version": "0.7.3",
  "icon": "assets/icon.png",
  "publisher": "MarceloBarella",
  "repository": {
    "type": "git",
    "url": "https://github.com/Marcelo-Barella/cursor-sync.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:cursorSync.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorSync",
          "title": "Cursor Sync",
          "icon": "$(sync)"
        }
      ]
    },
    "views": {
      "cursorSync": [
        {
          "id": "cursorSync.sidebar",
          "name": "Cursor Sync",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cursorSync.syncNow",
          "when": "view == cursorSync.sidebar && cursorSync.configured",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "cursorSync.exportCurrentChatBundle",
          "when": "resourceScheme == 'cursor.composer'",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "cursorSync.exportCurrentChatBundle",
          "when": "resourceScheme == 'cursor.composer'",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "cursorSync.exportCurrentChatBundle",
          "when": "false"
        }
      ]
    },
    "commands": [
      {
        "command": "cursorSync.syncNow",
        "title": "Cursor Sync: Sync Now",
        "icon": "$(sync)",
        "enablement": "cursorSync.configured"
      },
      {
        "command": "cursorSync.configureGithub",
        "title": "Cursor Sync: Configure GitHub"
      },
      {
        "command": "cursorSync.push",
        "title": "Cursor Sync: Push Now",
        "icon": "$(cloud-upload)",
        "enablement": "cursorSync.configured"
      },
      {
        "command": "cursorSync.pull",
        "title": "Cursor Sync: Pull Now",
        "icon": "$(cloud-download)",
        "enablement": "cursorSync.configured"
      },
      {
        "command": "cursorSync.showStatus",
        "title": "Cursor Sync: Show Status"
      },
      {
        "command": "cursorSync.resolveConflicts",
        "title": "Cursor Sync: Resolve Conflicts",
        "enablement": "cursorSync.hasConflicts"
      },
      {
        "command": "cursorSync.reset",
        "title": "Cursor Sync: Reset Extension State"
      },
      {
        "command": "cursorSync.export",
        "title": "Cursor Sync: Export Settings to Private Gist"
      },
      {
        "command": "cursorSync.import",
        "title": "Cursor Sync: Import Settings from Private Gist"
      },
      {
        "command": "cursorSync.exportTranscripts",
        "title": "Cursor Sync: Export Agent Transcripts to Private Gist"
      },
      {
        "command": "cursorSync.importTranscripts",
        "title": "Cursor Sync: Import Agent Transcripts from Private Gist"
      },
      {
        "command": "cursorSync.saveChatLocal",
        "title": "Cursor Sync: Save Chat Locally"
      },
      {
        "command": "cursorSync.loadChatLocal",
        "title": "Cursor Sync: Load Chat from Local Bundle"
      },
      {
        "command": "cursorSync.importChatBundle",
        "title": "Cursor Sync: Import Chat Bundle"
      },
      {
        "command": "cursorSync.exportChatBundle",
        "title": "Cursor Sync: Export Chat Bundle"
      },
      {
        "command": "cursorSync.exportCurrentChatBundle",
        "title": "Cursor Sync: Export into Bundle",
        "icon": "$(archive)"
      },
      {
        "command": "cursorSync.importChatBundleActivate",
        "title": "Cursor Sync: Import Chat Bundle (Activate)"
      },
      {
        "command": "cursorSync.verifyChatImport",
        "title": "Cursor Sync: Verify Chat Import"
      },
      {
        "command": "cursorSync.exportChatToGist",
        "title": "Cursor Sync: Export Chat to Private Gist"
      },
      {
        "command": "cursorSync.importChatFromGist",
        "title": "Cursor Sync: Import Chat from Private Gist"
      },
      {
        "command": "cursorSync.refreshImportedTranscripts",
        "title": "Cursor Sync: Refresh Imported Transcripts (Deprecated)"
      },
      {
        "command": "cursorSync.openImportedTranscript",
        "title": "Cursor Sync: Open Imported Transcript (Deprecated)"
      },
      {
        "command": "cursorSync.revealImportedTranscriptInExplorer",
        "title": "Cursor Sync: Reveal Imported Transcript in Explorer (Deprecated)"
      },
      {
        "command": "cursorSync.importTranscriptsFromGist",
        "title": "Cursor Sync: Import Transcripts from Gist URL",
        "icon": "$(cloud-download)"
      },
      {
        "command": "cursorSync.prepareStateReconciliation",
        "title": "Cursor Sync: Prepare State Reconciliation (chats.json)"
      },
      {
        "command": "cursorSync.finalizeStateReconciliation",
        "title": "Cursor Sync: Finalize Pending State Reconciliation"
      },
      {
        "command": "cursorSync.prepareSyncFromLandingZone",
        "title": "Cursor Sync: Prepare Sync from Landing Zone"
      },
      {
        "command": "cursorSync.installSkillTransportChat",
        "title": "Cursor Sync: Install Skill - Transport Chat"
      }
    ],
    "configuration": {
      "title": "Cursor Sync",
      "properties": {
        "cursorSync.enabledPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "settings.json",
            "keybindings.json",
            "snippets/**",
            "extensions.json",
            "vsix/**",
            "skills/**",
            "commands/**/*.md",
            "rules/*.mdc"
          ],
          "description": "Glob patterns for included sync paths"
        },
        "cursorSync.excludeGlobs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude from sync"
        },
        "cursorSync.schedule.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable periodic auto-sync (pull and push)"
        },
        "cursorSync.schedule.intervalMin": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "Minutes between scheduled syncs"
        },
        "cursorSync.maxFileSizeKB": {
          "type": "number",
          "default": 512,
          "description": "Skip files larger than this size in KB"
        },
        "cursorSync.syncProfileName": {
          "type": "string",
          "default": "default",
          "description": "Profile name written to manifest"
        },
        "cursorSync.safeMode": {
          "type": "boolean",
          "default": true,
          "description": "Require confirmation before pull overwrites local files"
        },
        "cursorSync.syncExtensions.autoInstall": {
          "type": "boolean",
          "default": true,
          "description": "On pull, automatically install extensions that are in the synced list but not installed locally"
        },
        "cursorSync.syncExtensions.autoUninstall": {
          "type": "boolean",
          "default": false,
          "description": "On pull, automatically uninstall extensions that are installed locally but not in the synced list (use with caution)"
        },
        "cursorSync.transcripts.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable agent transcript export/import (opt-in; transcripts may contain sensitive data)"
        },
        "cursorSync.transcripts.maxFileSizeKB": {
          "type": "number",
          "default": 2048,
          "description": "Skip transcript files larger than this size in KB"
        },
        "cursorSync.transcripts.importFallbackToCurrentWorkspace": {
          "type": "boolean",
          "default": true,
          "description": "When manual project mapping is empty, offer mapping all source projects to the local ~/.cursor/projects/ folder that matches the open workspace"
        },
        "cursorSync.transcripts.autoReloadAfterImport": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reload Cursor after importing transcripts (skips the reload prompt)"
        },
        "cursorSync.chatImport.activateDefault": {
          "type": "boolean",
          "default": false,
          "description": "Run composer.createComposer activation after disk restore when importing a chat bundle (import-v2)"
        },
        "cursorSync.chatImport.activateStrict": {
          "type": "boolean",
          "default": false,
          "description": "Fail import if activation is staged only (no confirmed composer.createComposer or result.json)"
        },
        "cursorSync.chatImport.bridgeWaitResultSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Seconds to poll ~/.cursor/import-activation/result.json after staging activation (0 = no wait)"
        },
        "cursorSync.chatImport.pingServer": {
          "type": "boolean",
          "default": false,
          "description": "After activation, run agentClient server probe stub (v1: logs only, not implemented)"
        },
        "cursorSync.chatImport.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a Python 3 interpreter for chat-transport scripts. Empty = auto-detect (python3, python)."
        },
        "cursorSync.chatImport.transportChatScriptDir": {
          "type": "string",
          "default": "",
          "description": "User-level override directory for transport-chat scripts (cursor_chat_io.py, cursor_composer_bridge.py). Workspace settings are ignored for security. Empty = use the extension's bundled scripts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "test": "vitest run",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "minimatch": "^10.0.0"
  }
}
