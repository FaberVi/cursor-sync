{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-extension",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Watching\\.\\.\\.$"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "build-extension",
      "type": "npm",
      "script": "build",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
